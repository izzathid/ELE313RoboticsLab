/*

- Task 2: Object following with melody
- 
- Behaviour:
- - SEARCH : robot rotates slowly, blue LEDs, no sound
- - FOLLOW : robot follows object, purple LEDs, STARWARS melody plays
- - HOLD   : robot stops (object too close), red LEDs, melody stops
- 
- Sensor layout (top view):
- ```
          front
           ```
-      7        0
-    6             1
-    5             2
-      4        3
          ...
          back
  ```

*/

#include <math.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include <ch.h>
#include <hal.h>
#include <main.h>
#include <leds.h>
